
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف مساعدة
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email.lower() == 'tech.support.app@gmail.com';
    }

    // قواعد مجموعة المستخدمين والبيانات التابعة لهم
    match /users/{userId} {
      // السماح بالقراءة العامة لدعم بوابة ولي الأمر ورؤية اسم المدرس
      allow read: if true; 
      // المدرس أو المسؤول فقط يمكنهم التعديل
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // الطلاب التابعين للمعلم
      match /students/{studentId} {
        allow read: if true; // وصول عام لولي الأمر
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // سجلات الحضور
      match /attendance/{attendanceId} {
        allow read: if true; // وصول عام لولي الأمر
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // سجلات المدفوعات
      match /payments/{paymentId} {
        allow read: if true; // وصول عام لولي الأمر
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // الإعدادات الخاصة (مثل جدول المواعيد)
      match /config/{document=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    // طلبات حذف الحساب
    match /deletionRequests/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // أذونات التقييم
    match /reviewPermissions/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // التقييمات العامة
    match /reviews/{reviewId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // قواعد المجموعات (للإدارة العامة)
    match /{path=**}/students/{studentId} {
      allow read: if isAdmin();
    }
    match /{path=**}/attendance/{attendanceId} {
      allow read: if isAdmin();
    }
    match /{path=**}/payments/{paymentId} {
      allow read: if isAdmin();
    }

    // رسائل اتصل بنا
    match /contactMessages/{messageId} {
      allow read, write, delete: if isAdmin();
      allow create: if true; 
    }

    // إعدادات التطبيق العامة
    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
