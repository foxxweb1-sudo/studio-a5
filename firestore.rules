rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // الدوال الأساسية للتحقق
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email.lower() == 'tech.support.app@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // قواعد بيانات المستخدمين والمجموعات الفرعية
    match /users/{userId} {
      // السماح بقراءة البروفايل لأي مستخدم مسجل، وللأدمن
      allow get: if true;
      allow list: if isAdmin() || isSignedIn(); 
      allow write: if isOwner(userId) || isAdmin();

      // السماح بالوصول الكامل للمالك والأدمن لكافة المجموعات الفرعية
      // والسماح بالقراءة العامة (لأغراض بوابة الأهل)
      match /students/{id} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
      match /attendance/{id} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
      match /payments/{id} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
      match /exams/{id} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
      
      // الإعدادات الخاصة بالمعلم
      match /config/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // قواعد المجموعات المشتركة (Collection Group) لدعم بوابة الأهل والبحث العام
    match /{path=**}/students/{id} { allow read: if true; }
    match /{path=**}/attendance/{id} { allow read: if true; }
    match /{path=**}/payments/{id} { allow read: if true; }
    match /{path=**}/exams/{id} { allow read: if true; }

    // رسائل التواصل (الإدارة فقط)
    match /contactMessages/{messageId} {
      allow read, write, delete: if isAdmin();
      allow create: if true; 
    }

    // إعدادات النظام العامة
    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // طلبات حذف الحساب
    match /deletionRequests/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // التقييمات
    match /reviewPermissions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isSignedIn() || isAdmin();
    }
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}