
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'tech.support.app@gmail.com';
    }

    // Rules for all users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // Rules for user-specific data (students, attendance, payments)
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Collection Group Rules
    match /{path=**}/students/{studentId} {
      allow read: if isAdmin();
    }
    match /{path=**}/attendance/{attendanceId} {
      allow read: if isAdmin();
    }
    match /{path=**}/payments/{paymentId} {
      allow read: if isAdmin();
    }

    // Rules for contact messages
    match /contactMessages/{messageId} {
      allow read: if isAdmin();
      allow create: if true; 
      allow update, delete: if false; 
    }

    // Rules for global app configuration
    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Security Rules Sync: Last update triggered on 2024-05-20 12:00:00
    // This comment ensures that the security rules file is considered updated by the watcher.
  }
}
