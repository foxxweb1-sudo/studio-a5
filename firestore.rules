
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف مساعدة
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email.lower() == 'tech.support.app@gmail.com';
    }

    // السماح للمشرف بقراءة كافة الطلاب والمدفوعات والحضور عبر Collection Groups
    match /{path=**}/students/{id} {
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == path.split('/')[1]);
    }

    match /{path=**}/attendance/{id} {
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == path.split('/')[1]);
    }

    match /{path=**}/payments/{id} {
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == path.split('/')[1]);
    }

    // قواعد المستخدمين (المعلمين)
    match /users/{userId} {
      allow get: if true; 
      allow list: if isAdmin(); 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

      match /config/{document=**} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }
    }
    
    // طلبات الحذف والتقييمات
    match /deletionRequests/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /reviewPermissions/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // رسائل اتصل بنا
    match /contactMessages/{messageId} {
      allow read, write, delete: if isAdmin();
      allow create: if true; 
    }

    // إعدادات التطبيق العامة
    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
