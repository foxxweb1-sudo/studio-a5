
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "WorkingSchedule": { "title": "WorkingSchedule", "type": "object", "properties": { "isActive": { "type": "boolean" } } },
    "PaymentConfig": { "title": "PaymentConfig", "type": "object", "properties": { "grades": { "type": "object" } } },
    "DeletionRequest": { "title": "DeletionRequest", "type": "object", "properties": { "uid": { "type": "string" } } },
    "Student": { "title": "Student", "type": "object", "properties": { "name": { "type": "string" }, "grade": { "type": "string" } } },
    "AttendanceRecord": { "title": "AttendanceRecord", "type": "object", "properties": { "studentId": { "type": "string" }, "status": { "type": "string" } } },
    "Payment": { "title": "Payment", "type": "object", "properties": { "studentId": { "type": "string" }, "amount": { "type": "number" } } },
    "ExamResult": { "title": "ExamResult", "type": "object", "properties": { "studentId": { "type": "string" }, "score": { "type": "number" }, "totalScore": { "type": "number" }, "date": { "type": "string" } } },
    "ContactMessage": { "title": "ContactMessage", "type": "object", "properties": { "name": { "type": "string" }, "status": { "type": "string" } } },
    "Review": { "title": "Review", "type": "object", "properties": { "rating": { "type": "number" } } },
    "GlobalConfig": { "title": "GlobalConfig", "type": "object", "properties": { "appName": { "type": "string" } } }
  },
  "auth": { "providers": ["password"] },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User" } },
      { "path": "/users/{userId}/students/{studentId}", "definition": { "entityName": "Student" } },
      { "path": "/users/{userId}/attendance/{attendanceId}", "definition": { "entityName": "AttendanceRecord" } },
      { "path": "/users/{userId}/payments/{paymentId}", "definition": { "entityName": "Payment" } },
      { "path": "/users/{userId}/exams/{examId}", "definition": { "entityName": "ExamResult" } },
      { "path": "/contactMessages/{messageId}", "definition": { "entityName": "ContactMessage" } },
      { "path": "/appConfig/{configId}", "definition": { "entityName": "GlobalConfig" } }
    ]
  }
}
