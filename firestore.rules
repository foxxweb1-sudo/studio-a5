
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email.lower() == 'tech.support.app@gmail.com';
    }

    match /users/{userId}/students/{studentId} {
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /users/{userId}/attendance/{id} {
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /users/{userId}/payments/{id} {
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /users/{userId}/exams/{id} {
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /{path=**}/students/{id} { allow read: if true; }
    match /{path=**}/attendance/{id} { allow read: if true; }
    match /{path=**}/payments/{id} { allow read: if true; }
    match /{path=**}/exams/{id} { allow read: if true; }

    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin(); 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      match /config/{document=**} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }
    }
    
    match /deletionRequests/{userId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
    }

    match /reviewPermissions/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow read, write, delete: if isAdmin();
      allow create: if true; 
    }

    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
