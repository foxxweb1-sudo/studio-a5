/**
 * @file firestore.rules
 * @description Firestore Security Rules for the Student Management App.
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model. The system assumes a 1:1 relationship
 * between an authenticated user and a student profile, where the user's authentication UID
 * is used as the student's document ID (`studentId`). Each user can only access and manage
 * their own data.
 *
 * ## Data Structure
 * All student-specific data is hierarchically organized under the '/students/{studentId}' path.
 * This includes the student's main profile document and their related subcollections for
 * attendance and payments. This structure ensures that all data related to a single student
 * is contained within their own data tree.
 *
 * ## Key Security Decisions
 * - **No Public Listing:** Listing all students in the top-level '/students' collection is
 *   explicitly disallowed to protect user privacy.
 * - **Strict Ownership:** All read and write operations within a student's data tree
 *   (e.g., /students/{studentId}/...) are restricted to the authenticated user whose UID
 *   matches the {studentId} in the path.
 * - **Path-based Security:** The rules rely on the document path for authorization, which is
 *   highly performant as it avoids extra database reads (`get()` calls) to check permissions.
 *
 * ## Denormalization for Authorization
 * To maintain relational integrity and simplify rules, a student's ID is denormalized within
 * their related documents. For example, an `AttendanceRecord` document contains a `studentId`
 * field. The rules enforce that this internal `studentId` field must always match the `studentId`
 * from the document's path, preventing data from being associated with the wrong student.
 *
 * ## Structural Segregation
 * This ruleset uses structural segregation by design. All private user data is placed in
 * subcollections under the user's root document (`/students/{studentId}`). There are no
 * public top-level collections, ensuring a clean separation of private data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Returns true if the user is signed in (authenticated).
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the signed-in user's UID matches the provided userId.
     * This is the core function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the user is the owner AND the document already exists.
     * Used for safe update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates required relational fields for a new Student document on create.
     * Ensures the document's internal `id` matches the document's path ID.
     */
    function hasValidStudentData(studentId) {
      return request.resource.data.id == studentId;
    }

    /**
     * Enforces immutability of the Student's `id` field on update.
     */
    function isStudentDataImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates required relational fields for a new AttendanceRecord on create.
     * Ensures the record's internal `studentId` matches its parent path.
     */
    function hasValidAttendanceData(studentId) {
      return request.resource.data.studentId == studentId;
    }

    /**
     * Enforces immutability of the AttendanceRecord's `studentId` on update.
     */
    function isAttendanceDataImmutable() {
      return request.resource.data.studentId == resource.data.id;
    }

    /**
     * Validates required relational fields for a new Payment record on create.
     * Ensures the record's internal `studentId` matches its parent path.
     */
    function hasValidPaymentData(studentId) {
      return request.resource.data.studentId == studentId;
    }

    /**
     * Enforces immutability of the Payment record's `studentId` on update.
     */
    function isPaymentDataImmutable() {
      return request.resource.data.studentId == resource.data.id;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description Controls access to a student's profile document.
     * @path /students/{studentId}
     * @allow (get) A logged-in user retrieves their own student document: `db.collection('students').doc('user_abc').get()` where auth.uid is 'user_abc'.
     * @allow (create) A new user creates their own student profile for the first time: `db.collection('students').doc('user_abc').set({ id: 'user_abc', ... })` where auth.uid is 'user_abc'.
     * @deny (get) An authenticated user tries to read another student's document: `db.collection('students').doc('user_xyz').get()` where auth.uid is 'user_abc'.
     * @deny (list) Any user, authenticated or not, tries to list all student documents: `db.collection('students').get()`.
     * @principle Restricts access to a user's own data tree and allows self-creation of a profile.
     */
    match /students/{studentId} {
      allow get: if isOwner(studentId);
      allow list: if false;
      allow create: if isOwner(studentId) && hasValidStudentData(studentId);
      allow update: if isExistingOwner(studentId) && isStudentDataImmutable();
      allow delete: if isExistingOwner(studentId);
    }

    /**
     * @description Controls access to a student's attendance records.
     * @path /students/{studentId}/attendance/{attendanceId}
     * @allow (list) A student lists their own attendance history: `db.collection('students/user_abc/attendance').get()` where auth.uid is 'user_abc'.
     * @allow (create) A student's device adds a new attendance record: `db.collection('students/user_abc/attendance').add({ studentId: 'user_abc', ... })` where auth.uid is 'user_abc'.
     * @deny (get) A student tries to get an attendance record for another student: `db.doc('students/user_xyz/attendance/record_123').get()` where auth.uid is 'user_abc'.
     * @deny (create) A student tries to create an attendance record under another student's profile: `db.collection('students/user_xyz/attendance').add(...)` where auth.uid is 'user_abc'.
     * @principle Enforces document ownership for all operations based on the parent document's ID. Validates relational integrity on create/update.
     */
    match /students/{studentId}/attendance/{attendanceId} {
      allow get: if isOwner(studentId);
      allow list: if isOwner(studentId);
      allow create: if isOwner(studentId) && hasValidAttendanceData(studentId);
      allow update: if isExistingOwner(studentId) && isAttendanceDataImmutable();
      allow delete: if isExistingOwner(studentId);
    }

    /**
     * @description Controls access to a student's payment records.
     * @path /students/{studentId}/payments/{paymentId}
     * @allow (list) A student lists their own payment history: `db.collection('students/user_abc/payments').get()` where auth.uid is 'user_abc'.
     * @allow (create) A student adds a new payment record: `db.collection('students/user_abc/payments').add({ studentId: 'user_abc', ... })` where auth.uid is 'user_abc'.
     * @deny (get) A student tries to get a payment record for another student: `db.doc('students/user_xyz/payments/payment_123').get()` where auth.uid is 'user_abc'.
     * @deny (update) A student tries to modify a payment record for another student: `db.doc('students/user_xyz/payments/payment_123').update(...)` where auth.uid is 'user_abc'.
     * @principle Enforces document ownership for all operations based on the parent document's ID. Validates relational integrity on create/update.
     */
    match /students/{studentId}/payments/{paymentId} {
      allow get: if isOwner(studentId);
      allow list: if isOwner(studentId);
      allow create: if isOwner(studentId) && hasValidPaymentData(studentId);
      allow update: if isExistingOwner(studentId) && isPaymentDataImmutable();
      allow delete: if isExistingOwner(studentId);
    }
  }
}