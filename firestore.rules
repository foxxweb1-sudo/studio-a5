
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف مساعدة
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email.lower() == 'tech.support.app@gmail.com';
    }

    // قواعد المستخدمين (المعلمين)
    match /users/{userId} {
      // السماح للقراءة العامة لبيانات المدرس (الاسم والصورة) ليراها ولي الأمر
      allow read: if true; 
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // الطلاب - السماح بقراءة ملف الطالب لولي الأمر
      match /students/{studentId} {
        allow read: if true; 
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // سجلات الحضور - السماح لولي الأمر بالقراءة والقوائم المفلترة
      match /attendance/{attendanceId} {
        allow read, list: if true;
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // سجلات المدفوعات - السماح لولي الأمر بالقراءة والقوائم المفلترة
      match /payments/{paymentId} {
        allow read, list: if true;
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // الإعدادات
      match /config/{document=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    // طلبات الحذف والتقييمات
    match /deletionRequests/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /reviewPermissions/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // رسائل اتصل بنا
    match /contactMessages/{messageId} {
      allow read, write, delete: if isAdmin();
      allow create: if true; 
    }

    // إعدادات التطبيق العامة
    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
