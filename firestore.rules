
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email.lower() == 'tech.support.app@gmail.com';
    }

    // Rules for all users collection
    match /users/{userId} {
      allow read: if true; // Allow public read for parent portal to see teacher name
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // Rules for deletion requests
    match /deletionRequests/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Rules for review permissions
    match /reviewPermissions/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Rules for reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow list: if true; // Fixed the permission error for admin/listing
      allow delete: if isAdmin();
    }
    
    // Rules for student-specific data (parent portal support)
    match /users/{userId}/students/{studentId} {
      allow read: if true; // Public read for parent portal via direct ID
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/attendance/{attendanceId} {
      allow read, list: if true; // Allow parent to see attendance
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/payments/{paymentId} {
      allow read, list: if true; // Allow parent to see payments
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Rules for other user config
    match /users/{userId}/config/{document=**} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Collection Group Rules (keeping for admin overview)
    match /{path=**}/students/{studentId} {
      allow read: if isAdmin();
    }
    match /{path=**}/attendance/{attendanceId} {
      allow read: if isAdmin();
    }
    match /{path=**}/payments/{paymentId} {
      allow read: if isAdmin();
    }

    // Rules for contact messages
    match /contactMessages/{messageId} {
      allow read, write, delete: if isAdmin();
      allow create: if true; 
    }

    // Rules for global app configuration
    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
