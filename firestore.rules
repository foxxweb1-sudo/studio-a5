rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // الدوال الأساسية للتحقق
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email.lower() == 'tech.support.app@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // قواعد بيانات المستخدمين والمجموعات الفرعية
    match /users/{userId} {
      // السماح بقراءة البروفايل (الاسم واللوجو) للجميع لظهوره في بوابة الأهل
      allow read: if true;
      // السماح بالعمليات الإدارية للمالك أو الأدمن فقط
      allow write: if isOwner(userId) || isAdmin();

      // --- سجلات الطلاب (بوابة الأهل والروابط العامة) ---
      // تم جعل القراءة (get & list) عامة تماماً لتعمل الروابط المباشرة وسجلات المعلم بسلاسة
      
      match /students/{id} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
      match /attendance/{id} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
      match /payments/{id} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
      match /exams/{id} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
      
      // الإعدادات الخاصة بالمعلم (مثل مواعيد العمل) - للمالك أو الأدمن فقط
      match /config/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // دعم استعلامات المجموعات المشتركة (Collection Group) 
    // لضمان عمل التقارير والروابط العامة تحت أي ظرف
    match /{path=**}/students/{id} { allow read: if true; }
    match /{path=**}/attendance/{id} { allow read: if true; }
    match /{path=**}/payments/{id} { allow read: if true; }
    match /{path=**}/exams/{id} { allow read: if true; }

    // بقية مجموعات النظام (رسائل التواصل)
    match /contactMessages/{messageId} {
      allow create: if true; 
      allow read, write, delete: if isAdmin();
    }

    // إعدادات التطبيق العامة (الهوية واللوجو)
    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // طلبات الحذف والخصوصية
    match /deletionRequests/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // نظام التقييمات
    match /reviewPermissions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isSignedIn() || isAdmin();
    }
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}