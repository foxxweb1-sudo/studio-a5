{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user, matching Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        }
      },
      "required": ["uid", "email"]
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Represents a student managed by a user.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The student's full name."
        },
        "grade": {
          "type": "string",
          "description": "The student's current grade level."
        },
        "phone": {
          "type": "string",
          "description": "The student's phone number."
        },
        "parentPhone": {
          "type": "string",
          "description": "Contact information for the student's parent or guardian."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the student was added."
        }
      },
      "required": ["name", "grade"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "type": "object",
      "description": "Represents a record of a student's attendance on a specific date.",
      "properties": {
        "studentId": {
          "type": "string",
          "description": "The ID of the student this record belongs to."
        },
        "date": {
          "type": "string",
          "description": "The date for which attendance is being recorded (YYYY-MM-DD).",
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": ["present"],
          "description": "The attendance status."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the record was created."
        }
      },
      "required": ["studentId", "date", "status"]
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "description": "Represents a payment made for a student.",
      "properties": {
        "studentId": {
          "type": "string",
          "description": "The ID of the student this payment is for."
        },
        "amount": {
          "type": "number",
          "description": "The amount of the payment."
        },
        "month": {
          "type": "string",
          "description": "The month for which the payment was made (YYYY-MM)."
        },
        "date": {
          "type": "string",
          "description": "The date the payment was recorded (YYYY-MM-DD).",
          "format": "date"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the payment was recorded."
        }
      },
      "required": ["studentId", "amount", "month", "date"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/students/{studentId}",
        "definition": {
          "entityName": "Student",
          "schema": {
            "$ref": "#/backend/entities/Student"
          },
          "description": "Stores student profiles for a specific user."
        }
      },
      {
        "path": "/users/{userId}/attendance/{attendanceId}",
        "definition": {
          "entityName": "AttendanceRecord",
          "schema": {
            "$ref": "#/backend/entities/AttendanceRecord"
          },
          "description": "Stores attendance records for all students of a specific user."
        }
      },
      {
        "path": "/users/{userId}/payments/{paymentId}",
        "definition": {
          "entityName": "Payment",
          "schema": {
            "$ref": "#/backend/entities/Payment"
          },
          "description": "Stores payment records for all students of a specific user."
        }
      }
    ]
  }
}
