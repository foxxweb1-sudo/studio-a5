rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'dr8wgLhCfRSGyjVR8Au5KxwUj0v1';
    }

    // Rules for all users collection
    match /users/{userId} {
      // الأدمن يقرأ الجميع، والمستخدم يقرأ ويحدث بياناته الخاصة فقط
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Rules for user-specific data (students, attendance, payments)
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Collection Group Rule for Students (Allows Admin to query across all users)
    match /{path=**}/students/{studentId} {
      allow read: if isAdmin();
    }

    // Rules for contact messages
    match /contactMessages/{messageId} {
      allow read: if isAdmin();
      allow create: if true; 
      allow update, delete: if false; 
    }
  }
}